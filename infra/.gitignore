# Terraform local state — actual state lives in S3 backends
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan

# Sensitive — should be set in CI vars / SSO, not committed
*.tfvars.local
*.auto.tfvars

# Generated by archive_file data sources at plan time; deterministic from
# placeholder/ source dirs, no value in committing. Glob covers suffixed
# names too (placeholder-webhook.zip, placeholder-response.zip, …).
modules/**/placeholder*.zip
